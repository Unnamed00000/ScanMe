rules_version = '2';

service cloud.firestore {
  function isAdmin() {
    return request.auth != null
      && request.auth.token.email == 'adam.margoev@gmail.com';
  }

  function isValidProfile(profileId) {
    return request.resource.data.slug is string
      && request.resource.data.slug == profileId
      && request.resource.data.published is bool
      && request.resource.data.id is string
      && request.resource.data.id == profileId;
  }

  match /databases/{database}/documents {
    match /profiles/{profileId} {
      allow get: if isAdmin() || resource == null || resource.data.published == true;
      allow list: if isAdmin();
      allow create, update: if isAdmin() && isValidProfile(profileId);
      allow delete: if isAdmin();
    }
  }
}
